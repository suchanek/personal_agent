# Personal AI Agent Environment Variables
# Copy this file to .env and fill in your actual API keys

# REQUIRED: Directory Configuration
# ROOT_DIR: Your home directory (used by filesystem MCP server)
# DATA_DIR: Directory for vector database storage  
ROOT_DIR="/Users/your_username"
DATA_DIR="/Users/your_username/data"

# OPTIONAL: API Keys for Enhanced Functionality
# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=""

# Brave Search API Key  
# Get from: https://api.search.brave.com/app/keys
BRAVE_API_KEY=""

# MULTIMODAL AGENTS: API Keys for Media Generation
# ModelsLab API Key
# Get from: https://modelslab.com/
MODELS_LAB_API_KEY=""

# ElevenLabs API Key  
# Get from: https://elevenlabs.io/
ELEVEN_LABS_API_KEY=""

# Giphy API Key
# Get from: https://developers.giphy.com/
GIPHY_API_KEY=""

